---
const startYear = 2026;
const currentYear = new Date().getFullYear();
const copyrightRange = currentYear > startYear ? `${startYear}-${currentYear}` : `${currentYear}`;
---

<footer class="mx-auto h-14 w-full max-w-[1320px] shrink-0 px-5 text-xs text-zinc-500 md:px-10">
  <div class="flex h-full items-center justify-between border-t border-white/10 pt-1">
    <p>Copyright © {copyrightRange} YangsAI. All Rights Reserved.</p>
    <p class="hidden md:block">Yangs AI - dedicated to discovering the fundamental principles of artificial intelligence.</p>
  </div>
</footer>
