---
import { portalNodes } from "../data/portalNodes";
import ExternalLinkIcon from "./ExternalLinkIcon.astro";

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

const normalizePath = (href?: string) => {
  if (!href || !href.startsWith("/")) {
    return null;
  }

  return href.replace(/\/+$/, "") || "/";
};

const isPathActive = (href?: string, mode: "exact" | "prefix" = "prefix") => {
  const normalizedHref = normalizePath(href);
  if (!normalizedHref) {
    return false;
  }

  if (mode === "exact") {
    return currentPath === normalizedHref;
  }

  if (normalizedHref === "/") {
    return currentPath === "/";
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const isEntryActive = (entry: { href: string; activeMatch?: "exact" | "prefix" }) =>
  isPathActive(entry.href, entry.activeMatch ?? "prefix");

const isNodeActive = (node: (typeof portalNodes)[number]) => {
  const subItemActive = node.subItems.some((item) => isPathActive(item.href, "prefix"));
  if (subItemActive) {
    return true;
  }

  if (node.fallbackLink?.href) {
    return isPathActive(node.fallbackLink.href, "prefix");
  }

  return false;
};

const isHomeActive = isPathActive("/", "exact");
const isNewsActive = isPathActive("/news", "prefix");
const isThanksActive = isPathActive("/thanks", "prefix");

---

<header class="z-50 border-b border-white/12 bg-[rgba(14,14,16,0.76)] backdrop-blur-xl" data-site-header>
  <div class="mx-auto flex h-20 max-w-[1320px] items-center justify-between px-5 md:px-10" data-site-header-row>
    <a href="/" aria-label="Go to Yangs AI homepage" class="flex min-w-0 shrink-0 items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-200/80" data-site-brand>
      <img src="/brand/favicon-32x32.png" alt="YangsAI logo" class="h-8 w-8 rounded-sm border border-white/15 bg-black/40" />
      <img src="/brand/yangs-ai-wordmark.svg" alt="Yangs AI" class="h-7 w-auto md:h-8" data-brand-wordmark />
    </a>
    <div class="ml-auto flex items-center gap-2 md:gap-3" data-site-header-controls>
      <nav class="site-nav-desktop items-center gap-3">
        <a
          href="/"
          data-nav-item
          data-nav-home
          data-active={isHomeActive ? "true" : "false"}
          class={`font-tech inline-flex h-9 cursor-pointer items-center rounded-lg border px-3 py-2 text-xs uppercase leading-none tracking-[0.12em] transition-colors ${isHomeActive ? "border-sky-200/70 bg-sky-200/22 text-sky-100" : "border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"}`}
        >
          Home
        </a>
        {portalNodes.map((node) => (
        (() => {
          const nodeActive = isNodeActive(node);
          const newsEntry = node.id === "founder" ? (
            <a
              href="/news"
              data-nav-item
              data-nav-news
              data-active={isNewsActive ? "true" : "false"}
              class={`font-tech inline-flex h-9 cursor-pointer items-center rounded-lg border px-3 py-2 text-xs uppercase leading-none tracking-[0.12em] transition-colors ${isNewsActive ? "border-sky-200/70 bg-sky-200/22 text-sky-100" : "border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"}`}
            >
              News
            </a>
          ) : null;
          const primaryEntries = [...node.subItems];
          const curatedEntries = [...node.links];
          if (primaryEntries.length === 0 && node.links.length === 0) {
            const fallback = node.fallbackLink;
            return (
              <>
              {newsEntry}
              <a
                href={fallback?.href || "#"}
                target={fallback?.external ? "_blank" : undefined}
                rel={fallback?.external ? "noreferrer" : undefined}
                data-draft-link={fallback?.draft || !fallback?.href ? "true" : undefined}
                data-nav-item
                data-active={isPathActive(fallback?.href) ? "true" : "false"}
                class={`font-tech inline-flex h-9 cursor-pointer items-center rounded-lg border px-3 py-2 text-xs uppercase leading-none tracking-[0.12em] transition-colors ${isPathActive(fallback?.href) ? "border-sky-200/70 bg-sky-200/22 text-sky-100" : "border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"}`}
              >
                <span>{node.label}</span>
                {fallback?.showExternalIndicator ? <ExternalLinkIcon /> : null}
              </a>
              </>
            );
          }

          return (
            <>
            {newsEntry}
            <div class="group relative">
              <button type="button" data-nav-item data-active={nodeActive ? "true" : "false"} class={`font-tech inline-flex h-9 cursor-pointer items-center rounded-lg border px-3 py-2 text-xs uppercase leading-none tracking-[0.12em] transition-colors ${nodeActive ? "border-sky-200/70 bg-sky-200/22 text-sky-100" : "border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"}`}>
                {node.label}
              </button>
              <div class="invisible pointer-events-none absolute right-0 top-full z-50 w-max max-w-[min(90vw,30rem)] pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100" data-nav-dropdown>
                <div class="rounded-xl border border-white/12 bg-[rgba(16,16,20,0.96)] p-2 shadow-[0_10px_30px_rgba(0,0,0,0.35)] backdrop-blur-md" data-nav-dropdown-panel>
                  {primaryEntries.map((entry) => (
                    <a
                      href={entry.href || "#"}
                      target={entry.external ? "_blank" : undefined}
                      rel={entry.external ? "noreferrer" : undefined}
                      data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                      data-nav-item
                      data-active={isEntryActive(entry) ? "true" : "false"}
                      class={`block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs ${isEntryActive(entry) ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/10"}`}
                    >
                      <span>{entry.label}</span>
                      {entry.showExternalIndicator ? <ExternalLinkIcon /> : null}
                    </a>
                  ))}

                  {curatedEntries.length > 0 ? (
                    <div class="group/curated relative mt-1">
                      <button
                        type="button"
                        class="font-tech flex w-full items-center justify-between gap-2 whitespace-nowrap rounded-md border border-white/10 bg-white/3 px-2 py-1.5 text-right text-[0.65rem] uppercase tracking-[0.1em] text-zinc-300 hover:bg-white/10"
                      >
                        <span>Curated Links</span>
                        <span aria-hidden="true">&#8250;</span>
                      </button>
                      <div class="invisible pointer-events-none absolute right-full top-1 z-50 mr-3 w-max max-w-[min(85vw,26rem)] opacity-0 transition duration-150 before:absolute before:-right-3 before:top-0 before:h-full before:w-3 before:content-[''] group-hover/curated:visible group-hover/curated:pointer-events-auto group-hover/curated:opacity-100 group-focus-within/curated:visible group-focus-within/curated:pointer-events-auto group-focus-within/curated:opacity-100" data-nav-curated-dropdown>
                        <div class="rounded-xl border border-white/12 bg-[rgba(16,16,20,0.98)] p-2 shadow-[0_14px_34px_rgba(0,0,0,0.42)] backdrop-blur-md" data-nav-curated-panel>
                          {curatedEntries.map((entry) => (
                            <a
                              href={entry.href || "#"}
                              target={entry.external ? "_blank" : undefined}
                              rel={entry.external ? "noreferrer" : undefined}
                              data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                              data-nav-item
                              data-active={isEntryActive(entry) ? "true" : "false"}
                              class={`block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs ${isEntryActive(entry) ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/10"}`}
                            >
                              <span>{entry.label}</span>
                              {entry.showExternalIndicator ? <ExternalLinkIcon /> : null}
                            </a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : null}
                </div>
              </div>
            </div>
            </>
          );
        })()
      ))}
        <a
          href="/thanks"
          data-nav-item
          data-nav-thanks
          data-active={isThanksActive ? "true" : "false"}
          class={`font-tech inline-flex h-9 cursor-pointer items-center rounded-lg border px-3 py-2 text-xs uppercase leading-none tracking-[0.12em] transition-colors ${isThanksActive ? "border-sky-200/70 bg-sky-200/22 text-sky-100" : "border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"}`}
        >
          Thanks
        </a>
      </nav>

      <details class="site-nav-mobile relative" data-mobile-menu>
        <summary class="font-tech cursor-pointer list-none rounded-lg border border-white/14 bg-white/4 px-3 py-2 text-xs uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/10">
          Menu
        </summary>
        <div class="absolute right-0 top-[calc(100%+0.45rem)] z-50 w-max max-w-[92vw] max-h-[70vh] overflow-auto rounded-xl border border-white/12 bg-[rgba(16,16,20,0.98)] p-2 shadow-[0_10px_30px_rgba(0,0,0,0.35)]" data-mobile-menu-panel>
          <details class="mb-1 rounded-lg border border-white/8 bg-white/3 p-1" data-mobile-top-link>
            <summary
              class={`font-tech cursor-pointer list-none whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs font-medium uppercase tracking-[0.12em] transition-colors ${isHomeActive ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/8"}`}
              data-mobile-menu-link
              data-mobile-nav-href="/"
              data-nav-item
              data-nav-home
              data-active={isHomeActive ? "true" : "false"}
            >
              Home
            </summary>
          </details>
          {portalNodes.map((node) => (
            (() => {
              const nodeActive = isNodeActive(node);
              const newsEntry = node.id === "founder" ? (
                <details class="mb-1 rounded-lg border border-white/8 bg-white/3 p-1" data-mobile-top-link>
                  <summary
                    class={`font-tech cursor-pointer list-none whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs font-medium uppercase tracking-[0.12em] transition-colors ${isNewsActive ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/8"}`}
                    data-mobile-menu-link
                    data-mobile-nav-href="/news"
                    data-nav-item
                    data-nav-news
                    data-active={isNewsActive ? "true" : "false"}
                  >
                    News
                  </summary>
                </details>
              ) : null;
              const primaryEntries = [...node.subItems];
              const curatedEntries = [...node.links];
              if (primaryEntries.length === 0 && node.links.length === 0) {
                const fallback = node.fallbackLink;
                return (
                  <>
                  {newsEntry}
                  <a
                    href={fallback?.href || "#"}
                    target={fallback?.external ? "_blank" : undefined}
                    rel={fallback?.external ? "noreferrer" : undefined}
                    data-draft-link={fallback?.draft || !fallback?.href ? "true" : undefined}
                    data-nav-item
                    data-active={isPathActive(fallback?.href) ? "true" : "false"}
                    class={`mb-1 block whitespace-nowrap rounded-lg border px-3 py-2 text-right text-xs font-medium uppercase tracking-[0.12em] transition-colors ${isPathActive(fallback?.href) ? "border-sky-200/60 bg-sky-200/20 text-sky-100" : "border-white/8 bg-white/3 text-zinc-200 hover:bg-white/8"}`}
                    data-mobile-menu-link
                  >
                    <span>{node.label}</span>
                    {fallback?.showExternalIndicator ? <ExternalLinkIcon class="ml-1 inline-block h-3 w-3 opacity-85 align-text-bottom" /> : null}
                  </a>
                  </>
                );
              }

              return (
                <>
                {newsEntry}
                <details class="mb-1 rounded-lg border border-white/8 bg-white/3 p-1" name="mobile-nav-category" data-mobile-submenu>
                  <summary data-nav-item data-active={nodeActive ? "true" : "false"} class={`font-tech cursor-pointer list-none rounded-md px-2 py-1.5 text-right text-xs font-medium uppercase tracking-[0.12em] ${nodeActive ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/8"}`}>
                    {node.label}
                  </summary>
                  <div class="mt-1 space-y-0.5 px-1 pb-1">
                    {primaryEntries.map((entry) => (
                      <a
                        href={entry.href || "#"}
                        target={entry.external ? "_blank" : undefined}
                        rel={entry.external ? "noreferrer" : undefined}
                        data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                        data-nav-item
                        data-active={isEntryActive(entry) ? "true" : "false"}
                        class={`block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs ${isEntryActive(entry) ? "bg-sky-200/20 text-sky-100" : "text-zinc-300 hover:bg-white/8 hover:text-zinc-100"}`}
                        data-mobile-menu-link
                      >
                        <span>{entry.label}</span>
                        {entry.showExternalIndicator ? <ExternalLinkIcon class="ml-1 inline-block h-3 w-3 opacity-85 align-text-bottom" /> : null}
                      </a>
                    ))}

                    {curatedEntries.length > 0 ? (
                      <details class="mt-1 rounded-md border border-white/8 bg-white/3 p-1" data-mobile-submenu>
                        <summary class="font-tech cursor-pointer list-none rounded-md px-2 py-1.5 text-right text-[0.65rem] uppercase tracking-[0.1em] text-zinc-300 hover:bg-white/8">
                          Curated Links
                        </summary>
                        <div class="mt-1 space-y-0.5 px-1 pb-1">
                          {curatedEntries.map((entry) => (
                            <a
                              href={entry.href || "#"}
                              target={entry.external ? "_blank" : undefined}
                              rel={entry.external ? "noreferrer" : undefined}
                              data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                              data-nav-item
                              data-active={isEntryActive(entry) ? "true" : "false"}
                              class={`block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs ${isEntryActive(entry) ? "bg-sky-200/20 text-sky-100" : "text-zinc-300 hover:bg-white/8 hover:text-zinc-100"}`}
                              data-mobile-menu-link
                            >
                              <span>{entry.label}</span>
                              {entry.showExternalIndicator ? <ExternalLinkIcon class="ml-1 inline-block h-3 w-3 opacity-85 align-text-bottom" /> : null}
                            </a>
                          ))}
                        </div>
                      </details>
                    ) : null}
                  </div>
                </details>
                </>
              );
            })()
          ))}
          <details class="mb-1 rounded-lg border border-white/8 bg-white/3 p-1" data-mobile-top-link>
            <summary
              class={`font-tech cursor-pointer list-none whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs font-medium uppercase tracking-[0.12em] transition-colors ${isThanksActive ? "bg-sky-200/20 text-sky-100" : "text-zinc-200 hover:bg-white/8"}`}
              data-mobile-menu-link
              data-mobile-nav-href="/thanks"
              data-nav-item
              data-nav-thanks
              data-active={isThanksActive ? "true" : "false"}
            >
              Thanks
            </summary>
          </details>
        </div>
      </details>

      <button
        type="button"
        data-theme-toggle
        class="font-tech inline-flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-lg border border-white/14 bg-white/4 text-zinc-200 hover:bg-white/10"
        aria-label="Toggle color theme"
        title="Toggle theme"
      >
        <span class="relative inline-flex h-4 w-4 items-center justify-center" aria-hidden="true">
          <svg data-theme-icon-sun viewBox="0 0 35 35" class="hidden h-4 w-4" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M17.5,25.88a8.38,8.38,0,1,1,8.38-8.38A8.389,8.389,0,0,1,17.5,25.88Zm0-14.26a5.88,5.88,0,1,0,5.88,5.88A5.887,5.887,0,0,0,17.5,11.62Z"/>
            <path fill="currentColor" d="M17.5,5.471h-.034A1.251,1.251,0,0,1,16.25,4.187l.075-2.721A1.267,1.267,0,0,1,17.609.25a1.251,1.251,0,0,1,1.215,1.284l-.075,2.721A1.249,1.249,0,0,1,17.5,5.471Z"/>
            <path fill="currentColor" d="M26.893,9.364a1.25,1.25,0,0,1-.859-2.158l1.978-1.871A1.25,1.25,0,0,1,29.73,7.151L27.752,9.022A1.242,1.242,0,0,1,26.893,9.364Z"/>
            <path fill="currentColor" d="M33.5,18.837h-.036l-2.722-.077a1.249,1.249,0,0,1-1.213-1.284,1.211,1.211,0,0,1,1.285-1.214l2.721.077a1.25,1.25,0,0,1-.035,2.5Z"/>
            <path fill="currentColor" d="M28.748,30.13a1.248,1.248,0,0,1-.909-.392L25.97,27.759a1.25,1.25,0,1,1,1.817-1.717l1.869,1.98a1.249,1.249,0,0,1-.908,2.108Z"/>
            <path fill="currentColor" d="M17.4,34.75h-.037a1.249,1.249,0,0,1-1.213-1.285l.079-2.721a1.25,1.25,0,0,1,2.5.072l-.079,2.721A1.249,1.249,0,0,1,17.4,34.75Z"/>
            <path fill="currentColor" d="M6.112,29.989a1.249,1.249,0,0,1-.857-2.159l1.98-1.867A1.25,1.25,0,1,1,8.95,27.781L6.969,29.648A1.242,1.242,0,0,1,6.112,29.989Z"/>
            <path fill="currentColor" d="M4.221,18.72H4.184l-2.721-.081A1.25,1.25,0,0,1,.251,17.352,1.237,1.237,0,0,1,1.537,16.14l2.721.081a1.25,1.25,0,0,1-.037,2.5Z"/>
            <path fill="currentColor" d="M8.135,9.335a1.248,1.248,0,0,1-.91-.393L5.359,6.961a1.25,1.25,0,1,1,1.82-1.715L9.046,7.228a1.251,1.251,0,0,1-.911,2.107Z"/>
          </svg>
          <svg data-theme-icon-moon viewBox="0 0 35 35" class="hidden h-4 w-4" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M18.44,34.68a18.22,18.22,0,0,1-2.94-.24,18.18,18.18,0,0,1-15-20.86A18.06,18.06,0,0,1,9.59.63,2.42,2.42,0,0,1,12.2.79a2.39,2.39,0,0,1,1,2.41L11.9,3.1l1.23.22A15.66,15.66,0,0,0,23.34,21h0a15.82,15.82,0,0,0,8.47.53A2.44,2.44,0,0,1,34.47,25,18.18,18.18,0,0,1,18.44,34.68ZM10.67,2.89a15.67,15.67,0,0,0-5,22.77A15.66,15.66,0,0,0,32.18,24a18.49,18.49,0,0,1-9.65-.64A18.18,18.18,0,0,1,10.67,2.89Z"/>
          </svg>
        </span>
        <span class="sr-only" data-theme-toggle-label>Toggle color theme</span>
      </button>
    </div>
  </div>
</header>

<div
  id="maintenance-overlay"
  data-maintenance-overlay
  class="pointer-events-none fixed inset-0 z-[130] flex items-center justify-center bg-[rgba(5,6,10,0.52)] opacity-0 backdrop-blur-[2px] transition duration-200"
  aria-hidden="true"
>
  <div data-maintenance-card class="w-[min(92vw,30rem)] rounded-2xl border border-amber-200/35 bg-[rgba(22,18,10,0.94)] px-6 py-5 text-center shadow-[0_18px_50px_rgba(0,0,0,0.45)]">
    <p class="font-tech text-sm uppercase tracking-[0.14em] text-amber-200">Under Maintenance</p>
    <p class="mt-2 text-sm text-zinc-100">This section is currently being maintained.</p>
    <p class="mt-1 text-sm text-zinc-100">Please check back soon.</p>
    <button
      type="button"
      data-maintenance-close
      class="mt-4 cursor-pointer rounded-lg border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-xs uppercase tracking-[0.12em] text-amber-100 transition hover:bg-amber-100/18 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-200/80"
    >
      Got It
    </button>
  </div>
</div>

<script>
  const THEME_KEY = "yangsai-theme";

  const getTheme = () => {
    const saved = window.localStorage.getItem(THEME_KEY);
    if (saved === "light" || saved === "dark") {
      return saved;
    }
    return "dark";
  };

  const syncThemeUi = () => {
    const theme = document.documentElement.dataset.theme === "light" ? "light" : "dark";
    document.documentElement.dataset.theme = theme;
    window.localStorage.setItem(THEME_KEY, theme);
    document.querySelectorAll("[data-theme-toggle-label]").forEach((el) => {
      el.textContent = theme === "dark" ? "Switch to light theme" : "Switch to dark theme";
    });

    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      if (button instanceof HTMLElement) {
        const nextLabel = theme === "dark" ? "Switch to light theme" : "Switch to dark theme";
        button.setAttribute("aria-label", nextLabel);
        button.setAttribute("title", nextLabel);
      }

      const sun = button.querySelector("[data-theme-icon-sun]");
      const moon = button.querySelector("[data-theme-icon-moon]");

      if (sun instanceof SVGElement) {
        sun.classList.toggle("hidden", theme !== "light");
      }
      if (moon instanceof SVGElement) {
        moon.classList.toggle("hidden", theme !== "dark");
      }
    });
  };

  document.documentElement.dataset.theme = getTheme();
  syncThemeUi();

  const showMaintenanceNotice = () => {
    const overlay = document.getElementById("maintenance-overlay");
    if (!(overlay instanceof HTMLElement)) return;

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    overlay.setAttribute("aria-hidden", "false");
  };

  window.addEventListener("show-maintenance-notice", showMaintenanceNotice);

  const hideMaintenanceNotice = () => {
    const overlay = document.getElementById("maintenance-overlay");
    if (!(overlay instanceof HTMLElement)) return;

    overlay.classList.remove("opacity-100");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "true");
  };

  const closeMobileMenu = () => {
    const menu = document.querySelector("details[data-mobile-menu]");
    const submenus = document.querySelectorAll("details[data-mobile-submenu]");
    const topLinks = document.querySelectorAll("details[data-mobile-top-link]");

    submenus.forEach((el) => el.removeAttribute("open"));
    topLinks.forEach((el) => el.removeAttribute("open"));
    menu?.removeAttribute("open");
  };

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const draftLink = target.closest("[data-draft-link]");
    if (draftLink) {
      event.preventDefault();
      showMaintenanceNotice();
    }

    if (target.closest("[data-maintenance-close]")) {
      hideMaintenanceNotice();
    }

    if (target instanceof HTMLElement && target.id === "maintenance-overlay") {
      hideMaintenanceNotice();
    }

    const themeToggle = target.closest("[data-theme-toggle]");
    if (themeToggle) {
      const current = document.documentElement.dataset.theme === "light" ? "light" : "dark";
      document.documentElement.dataset.theme = current === "dark" ? "light" : "dark";
      syncThemeUi();
      return;
    }

    const summaryNav = target.closest("summary[data-mobile-nav-href]");
    if (summaryNav instanceof HTMLElement) {
      const href = summaryNav.getAttribute("data-mobile-nav-href");
      if (href) {
        event.preventDefault();
        closeMobileMenu();
        window.location.assign(href);
      }
      return;
    }

    const mobileMenu = document.querySelector("details[data-mobile-menu]");
    if (
      mobileMenu instanceof HTMLDetailsElement &&
      mobileMenu.hasAttribute("open") &&
      !target.closest("details[data-mobile-menu]")
    ) {
      closeMobileMenu();
      return;
    }

    if (!target.closest("[data-mobile-menu-link]")) return;

    closeMobileMenu();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      hideMaintenanceNotice();
    }
  });

  document.addEventListener(
    "toggle",
    (event) => {
      const target = event.target;
      if (target instanceof HTMLDetailsElement && target.hasAttribute("data-mobile-top-link")) {
        target.removeAttribute("open");
      }
    },
    true,
  );
</script>
