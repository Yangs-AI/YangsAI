---
import { portalNodes } from "../data/portalNodes";
---

<header class="z-50 border-b border-white/12 bg-[rgba(14,14,16,0.76)] backdrop-blur-xl">
  <div class="mx-auto flex h-20 max-w-[1320px] items-center justify-between px-5 md:px-10">
    <a href="/" aria-label="Go to Yangs AI homepage" class="flex min-w-0 shrink-0 items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-zinc-200/80">
      <img src="/brand/favicon-32x32.png" alt="YangsAI logo" class="h-8 w-8 rounded-sm border border-white/15 bg-black/40" />
      <img src="/brand/yangs-ai-wordmark.svg" alt="Yangs AI" class="h-7 w-auto md:h-8" />
    </a>
    <nav class="hidden items-center gap-3 lg:flex">
      {portalNodes.map((node) => (
        (() => {
          const primaryEntries = [...node.subItems];
          const curatedEntries = [...node.links];
          if (primaryEntries.length === 0 && node.links.length === 0) {
            const fallback = node.fallbackLink;
            return (
              <a
                href={fallback?.href || "#"}
                target={fallback?.external ? "_blank" : undefined}
                rel={fallback?.external ? "noreferrer" : undefined}
                data-draft-link={fallback?.draft || !fallback?.href ? "true" : undefined}
                class="font-tech inline-flex cursor-pointer rounded-lg border border-white/14 bg-white/4 px-3 py-2 text-xs uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/10"
              >
                {node.label}
              </a>
            );
          }

          return (
            <div class="group relative">
              <button type="button" class="font-tech cursor-pointer rounded-lg border border-white/14 bg-white/4 px-3 py-2 text-xs uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/10">
                {node.label}
              </button>
              <div class="invisible pointer-events-none absolute right-0 top-full z-50 w-max max-w-[min(90vw,30rem)] pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100">
                <div class="rounded-xl border border-white/12 bg-[rgba(16,16,20,0.96)] p-2 shadow-[0_10px_30px_rgba(0,0,0,0.35)] backdrop-blur-md">
                  {primaryEntries.map((entry) => (
                    <a
                      href={entry.href || "#"}
                      target={entry.external ? "_blank" : undefined}
                      rel={entry.external ? "noreferrer" : undefined}
                      data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                      class="block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs text-zinc-200 hover:bg-white/10"
                    >
                      {entry.label}
                    </a>
                  ))}

                  {curatedEntries.length > 0 ? (
                    <div class="group/curated relative mt-1">
                      <button
                        type="button"
                        class="font-tech flex w-full items-center justify-between gap-2 whitespace-nowrap rounded-md border border-white/10 bg-white/3 px-2 py-1.5 text-right text-[0.65rem] uppercase tracking-[0.1em] text-zinc-300 hover:bg-white/10"
                      >
                        <span>Curated Links</span>
                        <span aria-hidden="true">&#8250;</span>
                      </button>
                      <div class="invisible pointer-events-none absolute right-full top-1 z-50 mr-3 w-max max-w-[min(85vw,26rem)] opacity-0 transition duration-150 before:absolute before:-right-3 before:top-0 before:h-full before:w-3 before:content-[''] group-hover/curated:visible group-hover/curated:pointer-events-auto group-hover/curated:opacity-100 group-focus-within/curated:visible group-focus-within/curated:pointer-events-auto group-focus-within/curated:opacity-100">
                        <div class="rounded-xl border border-white/12 bg-[rgba(16,16,20,0.98)] p-2 shadow-[0_14px_34px_rgba(0,0,0,0.42)] backdrop-blur-md">
                          {curatedEntries.map((entry) => (
                            <a
                              href={entry.href || "#"}
                              target={entry.external ? "_blank" : undefined}
                              rel={entry.external ? "noreferrer" : undefined}
                              data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                              class="block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs text-zinc-200 hover:bg-white/10"
                            >
                              {entry.label}
                            </a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ) : null}
                </div>
              </div>
            </div>
          );
        })()
      ))}
    </nav>

    <details class="relative lg:hidden" data-mobile-menu>
      <summary class="font-tech cursor-pointer list-none rounded-lg border border-white/14 bg-white/4 px-3 py-2 text-xs uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/10">
        Menu
      </summary>
      <div class="absolute right-0 top-[calc(100%+0.45rem)] z-50 w-max max-w-[92vw] max-h-[70vh] overflow-auto rounded-xl border border-white/12 bg-[rgba(16,16,20,0.98)] p-2 shadow-[0_10px_30px_rgba(0,0,0,0.35)]">
        {portalNodes.map((node) => (
          (() => {
            const primaryEntries = [...node.subItems];
            const curatedEntries = [...node.links];
            if (primaryEntries.length === 0 && node.links.length === 0) {
              const fallback = node.fallbackLink;
              return (
                <a
                  href={fallback?.href || "#"}
                  target={fallback?.external ? "_blank" : undefined}
                  rel={fallback?.external ? "noreferrer" : undefined}
                  data-draft-link={fallback?.draft || !fallback?.href ? "true" : undefined}
                  class="mb-1 block whitespace-nowrap rounded-lg border border-white/8 bg-white/3 px-3 py-2 text-right text-xs font-medium uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/8"
                  data-mobile-menu-link
                >
                  {node.label}
                </a>
              );
            }

            return (
              <details class="mb-1 rounded-lg border border-white/8 bg-white/3 p-1" name="mobile-nav-category" data-mobile-submenu>
                <summary class="font-tech cursor-pointer list-none rounded-md px-2 py-1.5 text-xs font-medium uppercase tracking-[0.12em] text-zinc-200 hover:bg-white/8">
                  {node.label}
                </summary>
                <div class="mt-1 space-y-0.5 px-1 pb-1">
                  {primaryEntries.map((entry) => (
                    <a
                      href={entry.href || "#"}
                      target={entry.external ? "_blank" : undefined}
                      rel={entry.external ? "noreferrer" : undefined}
                      data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                      class="block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs text-zinc-300 hover:bg-white/8 hover:text-zinc-100"
                      data-mobile-menu-link
                    >
                      {entry.label}
                    </a>
                  ))}

                  {curatedEntries.length > 0 ? (
                    <details class="mt-1 rounded-md border border-white/8 bg-white/3 p-1" data-mobile-submenu>
                      <summary class="font-tech cursor-pointer list-none rounded-md px-2 py-1.5 text-right text-[0.65rem] uppercase tracking-[0.1em] text-zinc-300 hover:bg-white/8">
                        Curated Links
                      </summary>
                      <div class="mt-1 space-y-0.5 px-1 pb-1">
                        {curatedEntries.map((entry) => (
                          <a
                            href={entry.href || "#"}
                            target={entry.external ? "_blank" : undefined}
                            rel={entry.external ? "noreferrer" : undefined}
                            data-draft-link={entry.draft || !entry.href ? "true" : undefined}
                            class="block whitespace-nowrap rounded-md px-2 py-1.5 text-right text-xs text-zinc-300 hover:bg-white/8 hover:text-zinc-100"
                            data-mobile-menu-link
                          >
                            {entry.label}
                          </a>
                        ))}
                      </div>
                    </details>
                  ) : null}
                </div>
              </details>
            );
          })()
        ))}
      </div>
    </details>
  </div>
</header>

<div
  id="maintenance-overlay"
  class="pointer-events-none fixed inset-0 z-[130] flex items-center justify-center bg-[rgba(5,6,10,0.52)] opacity-0 backdrop-blur-[2px] transition duration-200"
  aria-hidden="true"
>
  <div class="w-[min(92vw,30rem)] rounded-2xl border border-amber-200/35 bg-[rgba(22,18,10,0.94)] px-6 py-5 text-center shadow-[0_18px_50px_rgba(0,0,0,0.45)]">
    <p class="font-tech text-sm uppercase tracking-[0.14em] text-amber-200">Under Maintenance</p>
    <p class="mt-2 text-sm text-zinc-100">This section is currently being maintained.</p>
    <p class="mt-1 text-sm text-zinc-100">Please check back soon.</p>
    <button
      type="button"
      data-maintenance-close
      class="mt-4 cursor-pointer rounded-lg border border-amber-200/35 bg-amber-100/10 px-4 py-2 text-xs uppercase tracking-[0.12em] text-amber-100 transition hover:bg-amber-100/18 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-200/80"
    >
      Got It
    </button>
  </div>
</div>

<script>
  const showMaintenanceNotice = () => {
    const overlay = document.getElementById("maintenance-overlay");
    if (!(overlay instanceof HTMLElement)) return;

    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    overlay.setAttribute("aria-hidden", "false");
  };

  window.addEventListener("show-maintenance-notice", showMaintenanceNotice);

  const hideMaintenanceNotice = () => {
    const overlay = document.getElementById("maintenance-overlay");
    if (!(overlay instanceof HTMLElement)) return;

    overlay.classList.remove("opacity-100");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.setAttribute("aria-hidden", "true");
  };

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const draftLink = target.closest("[data-draft-link]");
    if (draftLink) {
      event.preventDefault();
      showMaintenanceNotice();
    }

    if (target.closest("[data-maintenance-close]")) {
      hideMaintenanceNotice();
    }

    if (target.id === "maintenance-overlay") {
      hideMaintenanceNotice();
    }

    if (!target.closest("[data-mobile-menu-link]")) return;

    const menu = document.querySelector("details[data-mobile-menu]");
    const submenus = document.querySelectorAll("details[data-mobile-submenu]");

    submenus.forEach((el) => el.removeAttribute("open"));
    menu?.removeAttribute("open");
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      hideMaintenanceNotice();
    }
  });
</script>
