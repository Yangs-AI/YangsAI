---
import SubpageLayout from "../../layouts/SubpageLayout.astro";
---

<SubpageLayout title="Team | About | Yangs AI" description="Introduction to the YangsAI team.">
  <a href="/research" class="text-sm text-zinc-300 hover:text-zinc-100">← Back to Research</a>
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.12em] text-zinc-300">Team</p>
  <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">About the Team</h1>

  <section class="mt-8 max-w-3xl space-y-4 rounded-xl border border-white/12 bg-white/5 px-6 py-7 text-zinc-200">
    <p>
      The YangsAI team brings together researchers and engineers working on fundamental AI principles,
      reproducible resources, and benchmark-centered evaluation.
    </p>
    <p>
      Team profiles are maintained as markdown pages so updates to biographies, interests, and contributions can
      be made quickly and consistently.
    </p>
    <a
      href="/team/members"
      class="inline-flex rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs text-zinc-100 hover:bg-white/16"
    >
      View Members
    </a>
  </section>
</SubpageLayout>
