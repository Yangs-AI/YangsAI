---
import { getCollection } from "astro:content";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";
import BackButton from "../../../components/BackButton.astro";

type StudentLevel = "undergraduate" | "master" | "phd";

const levelLabelMap: Record<StudentLevel, string> = {
  undergraduate: "Undergraduate",
  master: "Master",
  phd: "PhD",
};

const studentStatusText = (graduated: boolean) => (graduated ? "Graduated Student" : "Current Student");

const memberTypeLabel = (memberType: "employee" | "student") =>
  memberType === "employee" ? "Employee" : "Student";

const memberTypeTone = (memberType: "employee" | "student") =>
  memberType === "employee"
    ? "border-emerald-300/24 bg-emerald-300/10 text-emerald-100"
    : "border-zinc-200/18 bg-white/8 text-zinc-200";

const studentStatusTone = (graduated: boolean) =>
  graduated ? "border-amber-300/24 bg-amber-300/10 text-amber-100" : "border-sky-300/24 bg-sky-300/10 text-sky-100";

const studentLevelTone = "border-violet-300/24 bg-violet-300/10 text-violet-100";

const joinClassNames = (...parts: Array<string | false | null | undefined>) => parts.filter(Boolean).join(" ");

type MemberData = {
  memberType: "employee" | "student";
  studentLevel?: StudentLevel;
  graduated?: boolean;
  graduationYear?: number;
};

export async function getStaticPaths() {
  const entries = await getCollection("team-members");
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Member slug is required");
}

const entries = await getCollection("team-members");
const entry = entries.find((item) => item.id === slug || item.id.replace(/\.md$/, "") === slug);
if (!entry) {
  throw new Error(`Team member markdown not found for slug: ${slug}`);
}

const { Content } = await entry.render();
const data = entry.data;
const name = data.name;
const role = data.role;
const affiliation = data.affiliation;
const summary = data.summary;
const avatar = data.avatar;
const email = data.email;
const website = data.website;
const updatedOn = data.updatedOn;
const memberType = (data as MemberData).memberType;
const studentLevel = (data as MemberData).studentLevel;
const graduated = memberType === "student" ? (data as MemberData).graduated ?? false : false;
const graduationYear = memberType === "student" ? (data as MemberData).graduationYear : undefined;

const buildFallbackAvatar = (displayName: string, type: "employee" | "student") => {
  const escapedName = displayName
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");

  const hash = Array.from(displayName).reduce((acc, char) => acc * 31 + char.charCodeAt(0), 7);
  const unit = (offset: number) => {
    const x = Math.sin((hash + offset) * 12.9898) * 43758.5453;
    return x - Math.floor(x);
  };

  const palettes =
    type === "employee"
      ? [
          ["#345171", "#1a2533"],
          ["#3f5f52", "#1e2b25"],
          ["#4b446f", "#23203a"],
        ]
      : [
          ["#4f4c86", "#221f43"],
          ["#3e6a7a", "#1b2d38"],
          ["#6d5a3f", "#2f2619"],
        ];
  const skinTones = ["#f3d8bf", "#eac7a7", "#d9ac86", "#c89269", "#b67e57"];
  const hairColors = ["#1b1a1f", "#30261e", "#3c2f2a", "#2f3138", "#4a3a30"];

  const palette = palettes[Math.floor(unit(1) * palettes.length)];
  const skin = skinTones[Math.floor(unit(2) * skinTones.length)];
  const hair = hairColors[Math.floor(unit(3) * hairColors.length)];
  const shirtHue = Math.floor(190 + unit(4) * 110);
  const eyeOffset = 18 + Math.floor(unit(5) * 6);
  const mouthCurve = 8 + Math.floor(unit(6) * 6);
  const hairStyle = Math.floor(unit(7) * 3);

  const hairPath =
    hairStyle === 0
      ? "M 126 166 C 130 118, 164 92, 200 92 C 236 92, 270 118, 274 166 C 258 148, 236 138, 214 138 C 190 138, 168 148, 126 166 Z"
      : hairStyle === 1
      ? "M 126 166 C 122 120, 160 84, 200 84 C 244 84, 278 118, 274 166 C 254 142, 228 128, 196 128 C 172 128, 146 140, 126 166 Z"
      : "M 126 166 C 132 122, 162 98, 200 98 C 238 98, 268 122, 274 166 C 254 154, 236 150, 200 150 C 166 150, 146 154, 126 166 Z";

  const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 400' role='img' aria-label='${escapedName}'>
  <defs>
    <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
      <stop offset='0%' stop-color='${palette[0]}'/>
      <stop offset='100%' stop-color='${palette[1]}'/>
    </linearGradient>
    <radialGradient id='halo' cx='20%' cy='10%' r='76%'>
      <stop offset='0%' stop-color='rgba(247,251,255,0.34)'/>
      <stop offset='100%' stop-color='rgba(255,255,255,0)'/>
    </radialGradient>
  </defs>
  <rect width='400' height='400' fill='url(#g)'/>
  <rect width='400' height='400' fill='url(#halo)'/>
  <ellipse cx='200' cy='366' rx='130' ry='78' fill='hsl(${shirtHue}, 44%, 34%)' opacity='0.92'/>
  <circle cx='200' cy='190' r='74' fill='${skin}'/>
  <path d='${hairPath}' fill='${hair}'/>
  <circle cx='${200 - eyeOffset}' cy='190' r='5.2' fill='#1d1f24'/>
  <circle cx='${200 + eyeOffset}' cy='190' r='5.2' fill='#1d1f24'/>
  <path d='M 176 224 Q 200 ${224 + mouthCurve} 224 224' stroke='#694a38' stroke-width='3.2' fill='none' stroke-linecap='round'/>
</svg>`;

  return `data:image/svg+xml,${encodeURIComponent(svg)}`;
};

const fallbackAvatar = buildFallbackAvatar(name, memberType);
const avatarSrc = avatar || fallbackAvatar;
---

<SubpageLayout title={`${name} | Team | Yangs AI`} description={summary}>
  <BackButton href="/team/members" label="Back to Members" />

  <section class="mt-5 overflow-hidden rounded-2xl border border-white/14 bg-white/5" data-member-hero>
    <div class="pointer-events-none h-16 bg-gradient-to-r from-sky-300/18 via-cyan-300/8 to-emerald-300/16" aria-hidden="true"></div>
    <div class="px-5 pb-5 md:px-8 md:pb-7">
      <p class="font-tech -mt-2 text-xs uppercase tracking-[0.12em] text-zinc-300">Team Member</p>

      <div class="mt-3">
        <div class="flex flex-wrap items-center gap-4 md:gap-5">
          {avatar ? (
            <img
              src={avatarSrc}
              alt={`${name} portrait`}
              class="h-24 w-24 rounded-full border border-white/16 object-cover shadow-[0_10px_28px_rgba(0,0,0,0.24)]"
              loading="lazy"
              decoding="async"
              data-fallback-src={fallbackAvatar}
            />
          ) : (
            <img
              src={fallbackAvatar}
              alt={`${name} portrait`}
              class="h-24 w-24 rounded-full border border-white/16 object-cover shadow-[0_10px_28px_rgba(0,0,0,0.24)]"
              loading="lazy"
              decoding="async"
            />
          )}
          <div>
            <h1 class="text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">{name}</h1>
            <p class="mt-2 text-sm text-zinc-300">{role} · {affiliation}</p>
            <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
              <span data-member-tag="type" class={joinClassNames("rounded-full border px-2 py-0.5", memberTypeTone(memberType))}>
                {memberTypeLabel(memberType)}
              </span>
              {memberType === "student" && studentLevel ? (
                <span data-member-tag="level" class={joinClassNames("rounded-full border px-2 py-0.5", studentLevelTone)}>
                  {levelLabelMap[studentLevel]}
                </span>
              ) : null}
              {memberType === "student" ? (
                <span data-member-tag="status" class={joinClassNames("rounded-full border px-2 py-0.5", studentStatusTone(graduated))}>
                  {studentStatusText(graduated)}
                </span>
              ) : null}
              {memberType === "student" && graduated && graduationYear ? (
                <span class="text-zinc-400">Class of {graduationYear}</span>
              ) : null}
            </div>
          </div>
        </div>

      </div>

      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-zinc-200">{summary}</p>
    </div>
  </section>

  <div class="mt-4 flex flex-wrap items-center gap-2">
    {email ? (
      <a href={`mailto:${email}`} class="rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs font-medium text-zinc-100 break-all hover:bg-white/16">
        Email: {email}
      </a>
    ) : null}
    {website ? (
      <a href={website} target="_blank" rel="noreferrer" class="rounded-lg border border-zinc-100/24 bg-white/8 px-3 py-1.5 text-xs font-medium text-zinc-100 hover:bg-white/16">
        Website
      </a>
    ) : null}
    {updatedOn ? <span class="text-xs text-zinc-400">Updated: {updatedOn}</span> : null}
  </div>

  <article data-member-content class="mt-7 rounded-xl border border-white/12 bg-white/5 px-6 py-7 text-zinc-200 md:px-8 md:py-8 [&_h2]:mt-8 [&_h2]:border-b [&_h2]:border-white/12 [&_h2]:pb-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-zinc-100 [&_h3]:mt-6 [&_h3]:text-lg [&_h3]:font-medium [&_h3]:text-zinc-100 [&_p]:mt-3 [&_p]:leading-relaxed [&_a]:text-sky-200 [&_a]:underline [&_a]:underline-offset-4 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-5 [&_ol]:mt-3 [&_ol]:list-decimal [&_ol]:space-y-1.5 [&_ol]:pl-5 [&_blockquote]:mt-4 [&_blockquote]:rounded-lg [&_blockquote]:border-l-4 [&_blockquote]:border-sky-300/42 [&_blockquote]:bg-sky-300/8 [&_blockquote]:px-4 [&_blockquote]:py-2 [&_.callout]:mt-4 [&_.callout]:rounded-lg [&_.callout]:border [&_.callout]:border-white/16 [&_.callout]:bg-white/7 [&_.callout]:px-4 [&_.callout]:py-3 [&_.callout.note]:border-sky-300/38 [&_.callout.note]:bg-sky-300/12 [&_h2+ol]:mt-4 [&_h2+ol]:list-none [&_h2+ol]:space-y-3 [&_h2+ol]:pl-0 [&_h2+ol_li]:rounded-xl [&_h2+ol_li]:border [&_h2+ol_li]:border-white/14 [&_h2+ol_li]:bg-white/4 [&_h2+ol_li]:px-4 [&_h2+ol_li]:py-3 [&_h2+ol_li]:shadow-[0_8px_22px_rgba(0,0,0,0.12)] [&_h2+ol_li_p]:my-0 [&_h2+ol_li_p+p]:mt-1.5 [&_h2+ol_li_p:first-of-type]:text-zinc-100 [&_h2+ol_li_p:first-of-type]:font-semibold [&_h2+ol_li_p:first-of-type]:leading-snug [&_h2+ol_li_p:nth-of-type(2)]:text-zinc-200 [&_h2+ol_li_p:nth-of-type(3)]:text-sky-200 [&_h2+ol_li_p:nth-of-type(3)]:font-medium [&_h2+ol_li_p>strong]:font-inherit">
    <Content />
  </article>

  <script>
    document.querySelectorAll("img[data-fallback-src]").forEach((img) => {
      img.addEventListener("error", () => {
        const fallback = img.getAttribute("data-fallback-src");
        if (!fallback || img.getAttribute("src") === fallback) return;
        img.setAttribute("src", fallback);
      });
    });
  </script>
</SubpageLayout>
