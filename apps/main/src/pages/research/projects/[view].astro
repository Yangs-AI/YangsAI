---
import ProjectList from "../../../components/ProjectList.astro";
import BackButton from "../../../components/BackButton.astro";
import { projects } from "../../../data/projects";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";

export function getStaticPaths() {
  return [{ params: { view: "selected" } }];
}

const { view } = Astro.params;

if (view !== "selected") {
  return Astro.redirect("/research/projects");
}

const selectedProjects = projects.filter((project) => project.selected);

const selectedProjectsSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "url": "https://yangs.ai/research/projects/selected",
  "name": "Selected Projects | Yangs AI",
  "description": "Curated selected projects from Yangs AI research.",
  "publisher": { "@id": "https://yangs.ai/#organization" },
  "hasPart": selectedProjects.map((project) => ({
    "@type": "SoftwareApplication",
    "name": project.title,
    "description": project.summary,
    ...(project.codeUrl && { "codeRepository": project.codeUrl }),
    ...(project.projectUrl && { "url": project.projectUrl }),
  })),
};
---

<SubpageLayout title="Selected Projects | Yangs AI" description="Curated selected projects from Yangs AI research." schema={selectedProjectsSchema}>
  <BackButton href="/research/projects" label="All Projects" />
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.14em] text-zinc-300">Curated</p>
  <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Selected Projects</h1>
  <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-300">
    This page is the route-semantic subset for highlighted projects.
  </p>

  <ProjectList
    projects={selectedProjects}
    emptyMessage="No selected projects yet. Set selected: true in src/data/projects.ts."
  />
</SubpageLayout>
