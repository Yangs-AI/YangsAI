---
import SubpageLayout from "../../layouts/SubpageLayout.astro";
---

<SubpageLayout
  title="Research | Yangs AI"
  description="Research overview for Yangs AI, including papers, projects, and long-term directions."
>
  <p class="font-tech text-xs uppercase tracking-[0.14em] text-zinc-300">Yangs AI</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Overview</h1>
  <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-300">
    This section collects the core research threads of Yangs AI. Use the pages below to browse publications,
    ongoing projects, and forward-looking directions.
  </p>

  <div class="mt-10 grid gap-4 md:grid-cols-3">
    <a class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10" href="/research/papers">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-xl font-medium text-zinc-100">Papers</p>
      <p class="mt-1 text-sm text-zinc-300">Published and selected papers.</p>
    </a>

    <a class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10" href="/research/projects">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-xl font-medium text-zinc-100">Projects</p>
      <p class="mt-1 text-sm text-zinc-300">Current and archived project tracks.</p>
    </a>

    <a class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10" href="/research/directions">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Research</p>
      <p class="mt-2 text-xl font-medium text-zinc-100">Directions</p>
      <p class="mt-1 text-sm text-zinc-300">Long-term ideas and exploratory topics.</p>
    </a>
  </div>
</SubpageLayout>
