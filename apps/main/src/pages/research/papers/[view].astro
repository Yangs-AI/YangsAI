---
import PaperList from "../../../components/PaperList.astro";
import { papers } from "../../../data/papers";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";

export function getStaticPaths() {
  return [{ params: { view: "selected" } }];
}

const { view } = Astro.params;

if (view !== "selected") {
  return Astro.redirect("/research/papers");
}

const selectedPapers = papers.filter((paper) => paper.selected);
---

<SubpageLayout title="Selected Papers | Yangs AI" description="Curated selected papers from Yangs AI research.">
  <a href="/research/papers" class="text-sm text-zinc-300 hover:text-zinc-100">← All Papers</a>
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.14em] text-zinc-300">Curated</p>
  <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Selected Papers</h1>
  <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-300">
    This page is the route-semantic subset for highlighted publications. Keep it stable for sharing and external indexing.
  </p>

  <PaperList
    papers={selectedPapers}
    emptyMessage="No selected papers yet. Set selected: true in src/data/papers.ts."
  />
</SubpageLayout>
