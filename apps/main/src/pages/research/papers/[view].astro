---
import PaperList from "../../../components/PaperList.astro";
import BackButton from "../../../components/BackButton.astro";
import { papers } from "../../../data/papers";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";

export function getStaticPaths() {
  return [{ params: { view: "selected" } }];
}

const { view } = Astro.params;

if (view !== "selected") {
  return Astro.redirect("/research/papers");
}

const selectedPapers = papers.filter((paper) => paper.selected);

const selectedPapersSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "url": "https://yangs.ai/research/papers/selected",
  "name": "Selected Papers | Yangs AI",
  "description": "Curated selected papers from Yangs AI research.",
  "publisher": { "@id": "https://yangs.ai/#organization" },
  "hasPart": selectedPapers.map((paper) => ({
    "@type": "ScholarlyArticle",
    "headline": paper.title,
    "datePublished": paper.publishedOn,
    "author": paper.authors.map((a) => ({ "@type": "Person", "name": a.name })),
    ...(paper.paperUrl && { "url": paper.paperUrl }),
  })),
};
---

<SubpageLayout title="Selected Papers | Yangs AI" description="Curated selected papers from Yangs AI research." schema={selectedPapersSchema}>
  <BackButton href="/research/papers" label="All Papers" />
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.14em] text-zinc-300">Curated</p>
  <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Selected Papers</h1>
  <p class="mt-4 max-w-3xl text-base leading-relaxed text-zinc-300">
    This page is the route-semantic subset for highlighted publications. Keep it stable for sharing and external indexing.
  </p>

  <PaperList
    papers={selectedPapers}
    emptyMessage="No selected papers yet. Set selected: true in src/data/papers.ts."
  />
</SubpageLayout>
