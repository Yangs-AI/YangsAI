---

import "../styles/global.css";
import NeuralPortal from "../components/NeuralPortal";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(() => {
				const key = "yangsai-theme";
				const saved = window.localStorage.getItem(key);
				const theme =
					saved === "light" || saved === "dark"
						? saved
						: "dark";
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/brand/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/brand/favicon-16x16.png" />
		<link rel="icon" href="/brand/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" sizes="180x180" href="/brand/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#0d0d0f" />
		<meta name="apple-mobile-web-app-title" content="Yangs AI" />
		<title>Yangs AI</title>
		<meta
			name="description"
			content="Official Yangs AI website: research, datasets, benchmarks, and initiatives for fundamental AI."
		/>
	</head>
	<body class="flex min-h-screen flex-col overflow-x-hidden overflow-y-auto bg-transparent xl:h-screen xl:overflow-hidden">
		<SiteHeader />
		<main class="mx-auto w-full max-w-[1320px] px-2 pt-1 pb-3 md:px-6 md:pt-2 md:pb-4 xl:flex-1 xl:min-h-0">
			<NeuralPortal client:load />
		</main>
		<SiteFooter />
	</body>
</html>
